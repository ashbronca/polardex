# Copy to .env.local and fill in from your Supabase project:
#   Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Used ONLY by scripts/migrate-to-supabase.ts (one-time data import, never bundled).
# Service-role key bypasses RLS — keep it out of the client and out of git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
