rules_version = '2';

// Polardex is a single shared collection (one Pokédex). Reads are public so the
// mobile app's guest mode can browse; writes require a signed-in account.
//
// Signed-in accounts today: the web Studio account, plus mobile users `james`
// and `jane` (uids below). Sign-up is not exposed in either app. To lock writes
// down to exactly these owners, swap `request.auth != null` for:
//   allow write: if request.auth.uid in [
//     'IXC6OyKTRwRhP0awjreCX3IrI4C3', // james (mobile)
//     'JmKLLBRpxNONurPTOvwnIq2POSz2', // jane (mobile)
//     '<web-studio-uid>'              // find in Firebase console → Authentication
//   ];
service cloud.firestore {
  match /databases/{database}/documents {
    match /cards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pokemon/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /attributes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
